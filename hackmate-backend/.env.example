# Database
# Format: postgresql+psycopg2://<user>:<password>@<host>:<port>/<dbname>?sslmode=require
DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname?sslmode=require
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password

# JWT
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Service URLs (used by API Gateway)
AUTH_SERVICE_URL=http://locahost:8001
USER_SERVICE_URL=http://localhost:8002
TEAM_SERVICE_URL=http://localhost:8003
SCORING_SERVICE_URL=http://localhost:8004
SUBMISSION_SERVICE_URL=http://localhost:8005
NOTIFICATION_SERVICE_URL=http://localhost:8006
CHATBOT_SERVICE_URL=http://localhost:8007
ADMIN_SERVICE_URL=http://localhost:8008

# Redis (Upstash)
# Get these from your Upstash dashboard: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-redis-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token
REDIS_URL=rediss://default:your_upstash_redis_rest_token@your-redis-name.upstash.io:6379

# Push Notifications (VAPID keys)
# Generate with: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.private_key, v.public_key)"
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_CLAIMS_EMAIL=admin@yourdomain.com

# Optional: OpenAI for chatbot
# OPENAI_API_KEY=sk-your-key-here

# Optional: GitHub token — increases API rate limit from 60 to 5000 req/hr
# Generate at: https://github.com/settings/tokens (no scopes needed for public repos)
# GITHUB_API_TOKEN=your_github_pat_here
